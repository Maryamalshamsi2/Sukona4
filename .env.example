# Sukona environment variables.
#
# Copy this file to `.env.local` for development. For production,
# set every variable below in your hosting provider's environment
# settings (Vercel: Project Settings → Environment Variables).
#
# Anything starting with NEXT_PUBLIC_ is exposed to the browser
# bundle. Everything else is server-only — never reference these
# from client components.

# ---------------- Supabase ----------------
# Project URL + anon key — find these in Supabase Dashboard →
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service-role key. Bypasses RLS, used only by the Stripe webhook
# handler (no logged-in user, so no JWT is attached). Treat this
# like a password: never commit, never expose to the client, never
# put behind NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---------------- Stripe ------------------
# Dashboard → Developers → API keys. Use the TEST keys for dev
# (pk_test_..., sk_test_...). Swap to LIVE keys (pk_live_, sk_live_)
# in production.
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret.
# Dev: run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# and copy the secret it prints (starts with whsec_).
# Prod: Stripe Dashboard → Developers → Event destinations → your
# endpoint → "Signing secret" → Reveal.
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — six total (3 plans × 2 billing periods).
# Find these on each Price in Stripe Dashboard → Products. Format
# is `price_xxx`. Test mode and live mode have different IDs.
STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_SOLO_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...
STRIPE_PRICE_MULTITEAM_MONTHLY=price_...
STRIPE_PRICE_MULTITEAM_ANNUAL=price_...
